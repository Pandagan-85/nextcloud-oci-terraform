# ==============================================================================
# Environment Variables - Example Configuration
# ==============================================================================
# Copy this file to .env and fill in your actual values
#
# cp .env.example .env
# nano .env
#
# IMPORTANT: .env is in .gitignore - DO NOT commit it!
# ==============================================================================

# ==============================================================================
# ORACLE CLOUD INFRASTRUCTURE (for scripts)
# ==============================================================================

# Instance connection details
OCI_INSTANCE_IP=YOUR_INSTANCE_PUBLIC_IP
OCI_SSH_USER=ubuntu
OCI_SSH_KEY_PATH=~/.ssh/id_rsa

# Instance details
OCI_REGION=eu-frankfurt-1
OCI_SHAPE=VM.Standard.A1.Flex

# ==============================================================================
# DOMAIN CONFIGURATION
# ==============================================================================
# Your domain (e.g., dev.example.com, cloud.example.com)
# DNS A records must point to your server's public IP

DOMAIN=your-domain.example.com

# ==============================================================================
# SSL CONFIGURATION
# ==============================================================================

LETSENCRYPT_EMAIL=your-email@example.com

# ==============================================================================
# NEXTCLOUD CONFIGURATION
# ==============================================================================

NEXTCLOUD_DATA_DIR=/mnt/nextcloud-data
NEXTCLOUD_USER=your-nextcloud-username    # Used for Komga library path

# Apache and Talk ports (usually don't need to change)
APACHE_PORT=11000
TALK_PORT=3478

# Admin credentials (set during Nextcloud setup)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=your-secure-password-here

# ==============================================================================
# BACKUP CONFIGURATION
# ==============================================================================

# Backup retention (days)
BACKUP_RETENTION_DAYS=7
BACKUP_REMOTE_RETENTION_DAYS=30

# Nextcloud backup encryption password
# Generate with: openssl rand -hex 32
NEXTCLOUD_BACKUP_PASSWORD=your-backup-encryption-password

# Nextcloud backup passphrase (BorgBackup)
# Generate with: pwgen -s 64 1
# Or use a memorable phrase
NEXTCLOUD_PASSPHRASE="your backup passphrase here"

# ==============================================================================
# APP PASSWORDS (Optional - for device sync)
# ==============================================================================
# Generate these from Nextcloud Settings → Security → Devices & Sessions
# Format: xxxxx-xxxxx-xxxxx-xxxxx-xxxxx

# NEXTCLOUD_APP_PASSWORD_Device1=xxxxx-xxxxx-xxxxx-xxxxx-xxxxx
# NEXTCLOUD_APP_PASSWORD_Device2=xxxxx-xxxxx-xxxxx-xxxxx-xxxxx

# ==============================================================================
# MONITORING CONFIGURATION (Optional - Prometheus + Grafana)
# ==============================================================================

# Grafana admin password
# Generate with: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password

# Grafana accessible via Tailscale: https://YOUR_TAILSCALE_HOSTNAME:3000
# Default username: admin

# Data retention (Prometheus)
PROMETHEUS_RETENTION_DAYS=30

# ==============================================================================
# KOMGA CONFIGURATION (Manga/Comics Reader)
# ==============================================================================

# Komga accessible via Tailscale: https://YOUR_TAILSCALE_HOSTNAME:25600
# Library files are stored in /mnt/nextcloud-data/media/ (External Storage)
# This keeps them outside the Nextcloud datadir to exclude them from Borg backup
KOMGA_LIBRARY_PATH=/mnt/nextcloud-data/media/Fumetti

# ==============================================================================
# JELLYFIN CONFIGURATION (Media Server)
# ==============================================================================

# Jellyfin accessible via Tailscale: https://YOUR_TAILSCALE_HOSTNAME:8096
# Media files are stored in /mnt/nextcloud-data/media/ (External Storage)
# This keeps them outside the Nextcloud datadir to exclude them from Borg backup
# Use Finamp as mobile music client connecting to Jellyfin
JELLYFIN_VIDEO_PATH=/mnt/nextcloud-data/media/Video
JELLYFIN_MUSIC_PATH=/mnt/nextcloud-data/media/Music
JELLYFIN_PHOTOS_PATH=/mnt/nextcloud-data/media/Photos
JELLYFIN_PUBLISHED_URL=https://YOUR_TAILSCALE_HOSTNAME:8096

# ==============================================================================
# NOTES
# ==============================================================================
#
# Useful Commands:
#
# Access Nextcloud container:
#   docker exec -it nextcloud-aio-nextcloud bash
#
# Inside container, run OCC commands:
#   sudo -u www-data php occ status
#   sudo -u www-data php occ config:list
#   sudo -u www-data php occ maintenance:mode --on
#   sudo -u www-data php occ files:scan --all
#
# Check logs:
#   docker compose logs -f
#   docker compose logs nextcloud-aio-mastercontainer
#   docker compose logs caddy
#
# Backup commands:
#   ./scripts/create-backup.sh
#   ./scripts/download-backup.sh
#   ./scripts/export-data.sh
#
# ==============================================================================
